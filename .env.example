GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
RETAIL_SEARCH_MODEL=gemini-2.5-flash
RETAIL_SEARCH_GOOGLE_FALLBACK=true
# Optional. Enables structured store discovery through Google Places Text Search.
GOOGLE_PLACES_API_KEY=
GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Iapetus
PORT=3000

# Gmail SMTP email sending. Use a Gmail App Password, not your normal Gmail password.
EMAIL_PROVIDER=gmail
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
EMAIL_FROM="Financial App <your_gmail_address@gmail.com>"
EMAIL_DRY_RUN=true
